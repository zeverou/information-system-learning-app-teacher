# Controls whether the app is in STUDENT or TEACHER mode.
# TEACHER enables teacher mode; every other value disables it.
APP_MODE=

# Controls where default components are loaded from:
# system = system_components.json in the loaded system
# directory = app/model/SystemComponents/**/*.ts
LOAD_COMPONENTS_FROM=system

# Controls where system pages are loaded from:
# system = .vue files in the loaded system
# directory = static Nuxt pages in app/pages
LOAD_PAGES_FROM=system

# Controls whether student mode should be limited to a single system.
# When true (default), the app automatically navigates into the first available system.
# When false, the app displays the list of systems even in student mode.
SINGLE_SYSTEM=true
